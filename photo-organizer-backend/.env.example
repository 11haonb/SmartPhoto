# Application
APP_NAME=photo-organizer
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-string-in-production

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/photo_organizer

# Redis
REDIS_URL=redis://redis:6379/0

# SMS (Aliyun SMS Service)
SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
SMS_SIGN_NAME=your-sms-sign-name
SMS_TEMPLATE_CODE=your-sms-template-code

# SMS Verification
SMS_CODE_LENGTH=6
SMS_CODE_EXPIRE_SECONDS=300
SMS_RATE_LIMIT_SECONDS=60

# JWT
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# API Key Encryption (32-byte hex string)
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# Object Storage (MinIO for dev, COS for prod)
STORAGE_ENDPOINT=http://minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=photo-organizer
STORAGE_REGION=ap-guangzhou

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
